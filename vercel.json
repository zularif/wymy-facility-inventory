{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/inventory run build",
  "outputDirectory": "artifacts/inventory/dist",
  "framework": null,
  "functions": {
    "api/index.ts": { "maxDuration": 30 },
    "api/health.ts": { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
