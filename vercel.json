{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run typecheck:libs && pnpm --filter @workspace/inventory run build",
  "outputDirectory": "artifacts/inventory/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
